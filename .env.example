# Required — generate with: openssl rand -base64 32
JWT_SECRET=

# Optional: force secure cookies when using HTTPS (even outside NODE_ENV=production)
# COOKIE_SECURE=true

# Optional: enable Helmet security headers in development
# HELMET=true

# Optional: disable Vite HMR (npm run dev) if the page keeps hot-reloading / flashing
# BERAMETHODE_NO_HMR=1

# Optional: return reset code in JSON + log to console (development only; never in production)
# ALLOW_RESET_DEV_CODE=true

# Google Gemini — server only (used by /api/ai/*). Never exposed to the browser bundle.
GEMINI_API_KEY=

# SMTP Configuration
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=465
SMTP_USER=no-reply@yourdomain.com
SMTP_PASS=your_password_here
SMTP_SECURE=true

# RH / paie — ajustement type SAGE (priorité sur app_settings : même clés côté serveur)
# HR_SAGE_ROUNDING=15
# HR_SAGE_WORKDAY_START=06:00
# HR_SAGE_APPLY=true
