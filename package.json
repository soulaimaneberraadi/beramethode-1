{
  "name": "dashboard-proto",
  "version": "1.0.0",
  "description": "Minimal Node.js dashboard prototype",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:app": "tsx server.ts",
    "build": "vite build",
    "build:static": "vite build --mode static",
    "preview": "vite preview",
    "start": "npx tsx server.ts",
    "type-check": "tsc --noEmit",
    "electron:dev": "concurrently --kill-others-on-fail --names \"SERVER,ELECTRON\" \"npm run dev:app\" \"electron .\"",
    "electron:build:win": "tsup && vite build && electron-builder --win",
    "electron:rebuild": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "@google/genai": "^1.52.0",
    "@supabase/supabase-js": "^2.105.4",
    "@vitejs/plugin-react": "^6.0.1",
    "animejs": "^4.4.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "click-to-react-component": "^1.1.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.0",
    "framer-motion": "^12.38.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.16.0",
    "nodemailer": "^8.0.7",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-qr-code": "^2.0.21",
    "recharts": "^3.8.1",
    "vite": "^8.0.10",
    "vite-plugin-javascript-obfuscator": "^3.1.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "tsup": "^8.3.5",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "electron-updater": "^6.3.9",
    "@electron/rebuild": "^3.7.1",
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "build": {
    "appId": "com.beramethode.app",
    "productName": "BERAMETHODE",
    "asar": true,
    "asarUnpack": [
      "**/better-sqlite3/**",
      "**/node_modules/better-sqlite3/**"
    ],
    "files": [
      "dist/**",
      "electron/**",
      "node_modules/**",
      "!node_modules/.cache/**"
    ],
    "directories": {
      "output": "C:/Users/HP/3D Objects/beramethode exe"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BERAMETHODE"
    },
    "extraResources": [
      {
        "from": "dist-server",
        "to": "dist-server",
        "filter": ["**/*"]
      }
    ]
  }
}
